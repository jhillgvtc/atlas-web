{
  "rewrites": [
    { "source": "/:project", "destination": "/projects/:project/index.html" },
    { "source": "/:project/", "destination": "/projects/:project/index.html" },
    { "source": "/:project/:path*", "destination": "/projects/:project/:path*" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    }
  ]
}
